{
  "expo": {
    "name": "Draft",
    "slug": "draft",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "draft",
      "rc-6e2bf6b9ec"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F04444"
    },
    "ios": {
      "buildNumber": "3",
      "supportsTablet": true,
      "bundleIdentifier": "app.techtactoe.draft",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDisplayName": "Draft",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to select images for your bookmarks, notes, and projects",
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone"
      },
      "usesAppleSignIn": true
    },
    "android": {
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F04444"
      },
      "package": "app.techtactoe.draft",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "WAKE_LOCK",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Draft",
      "shortName": "Draft",
      "backgroundColor": "#F04444",
      "themeColor": "#F04444"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Draft accesses your photos so you can add images to bookmarks, notes, and projects."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#F04444",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBFirestore",
              "RNFBStorage",
              "RNFBAnalytics",
              "RNFBCrashlytics"
            ]
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.36179904713-cmkvd6fqe2srvg15pc87odocqh27ph6e"
        }
      ],
      "./plugins/withAndroidReleaseSigning.js",
      "expo-localization",
      [
        "expo-share-intent",
        {
          "iosShareExtensionName": "Draft",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": ["text/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleWebClientId": "36179904713-taogn2iie8n5u4amrkq5cp2rquckbhef.apps.googleusercontent.com",
      "aiFunctionsUrl": "https://us-central1-pinnedly-48c49.cloudfunctions.net/aiWorkspaceChat",
      "functionsBaseUrl": "https://europe-west1-pinnedly-48c49.cloudfunctions.net",
      "firebaseWeb": {
        "apiKey": "AIzaSyAMRSrAaduMS643iVZ2OAxEc_pgD1MXyZg",
        "authDomain": "pinnedly-48c49.firebaseapp.com",
        "projectId": "pinnedly-48c49",
        "storageBucket": "pinnedly-48c49.firebasestorage.app",
        "messagingSenderId": "36179904713"
      }
    }
  }
}
