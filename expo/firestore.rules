rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isRegisteredUser() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isPublicVisibility(visibility) {
      return visibility == 'public';
    }

    function isSharedWithUser() {
      return isSignedIn() && request.auth.uid in resource.data.get('sharedWith', []);
    }

    function canEditEntity() {
      return isOwner(resource.data.ownerId)
        || (isSignedIn() && request.auth.uid in resource.data.get('editors', []));
    }

    function accessFieldsAreUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['ownerId', 'sharedWith', 'editors']);
    }

    function isPremium(userId) {
      let path = /databases/$(database)/documents/subscriptionEntitlements/$(userId);
      return exists(path)
        && get(path).data.active == true
        && get(path).data.status in ['active', 'grace']
        && (get(path).data.get('expiresAtServer', null) == null
          || get(path).data.expiresAtServer > request.time);
    }

    function premiumVisibilityIsValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['visibility', 'isPublic'])
        || isPremium(resource.data.ownerId)
        || (request.resource.data.get('visibility', 'private') == 'private'
          && request.resource.data.get('isPublic', false) == false);
    }

    function premiumReminderIsValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reminderSchedule'])
        || isPremium(resource.data.ownerId)
        || (request.resource.data.reminderSchedule.intervalDays.size() <= 1
          && request.resource.data.reminderSchedule.get('customDates', []).size() == 0);
    }

    function premiumGalleryIsValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['gallery'])
        || isPremium(resource.data.ownerId);
    }

    function validEntityCreate() {
      return isRegisteredUser()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.get('sharedWith', []) == []
        && request.resource.data.get('editors', []) == [];
    }

    function canReadEntity() {
      return isOwner(resource.data.ownerId)
        || isPublicVisibility(resource.data.get('visibility', 'private'))
        || isSharedWithUser();
    }

    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function canAccessProject(projectId) {
      let project = projectData(projectId);
      return isOwner(project.ownerId)
        || isPublicVisibility(project.get('visibility', 'private'))
        || (isSignedIn() && request.auth.uid in project.get('sharedWith', []));
    }

    function canEditProject(projectId) {
      let project = projectData(projectId);
      return isOwner(project.ownerId)
        || (isSignedIn() && request.auth.uid in project.get('editors', []));
    }

    function canReadList() {
      return resource.data.isPublic == true
        || isPublicVisibility(resource.data.get('visibility', 'private'))
        || isOwner(resource.data.ownerId)
        || isSharedWithUser();
    }

    match /users/{userId} {
      allow read: if isRegisteredUser();
      allow create: if isRegisteredUser() && request.auth.uid == userId;
      allow update: if isRegisteredUser()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'avatar', 'bio', 'updatedAt']);
      allow delete: if isRegisteredUser() && request.auth.uid == userId;
    }

    match /notes/{noteId} {
      allow read: if canReadEntity();
      allow create, delete: if false;
      allow update: if isSignedIn() && canEditEntity()
        && accessFieldsAreUnchanged()
        && premiumVisibilityIsValid()
        && premiumReminderIsValid();
    }

    match /bookmarks/{bookmarkId} {
      allow read: if canReadEntity();
      allow create, delete: if false;
      allow update: if isRegisteredUser() && canEditEntity()
        && accessFieldsAreUnchanged()
        && premiumVisibilityIsValid()
        && premiumReminderIsValid();
    }

    match /projects/{projectId} {
      allow read: if canReadEntity();
      allow create, delete: if false;
      allow update: if isRegisteredUser() && canEditEntity()
        && accessFieldsAreUnchanged()
        && premiumVisibilityIsValid()
        && premiumGalleryIsValid();

      match /tasks/{taskId} {
        allow read: if canAccessProject(projectId);
        allow update: if isRegisteredUser() && canEditProject(projectId);
        allow create, delete: if false;
      }
    }

    match /todos/{todoId} {
      allow read: if canReadEntity();
      allow create, delete: if false;
      allow update: if isRegisteredUser() && canEditEntity()
        && accessFieldsAreUnchanged()
        && premiumReminderIsValid();
    }

    match /bookmarkLists/{listId} {
      allow read: if canReadList();
      allow create, delete: if false;
      allow update: if isRegisteredUser() && canEditEntity()
        && accessFieldsAreUnchanged()
        && premiumVisibilityIsValid();
    }

    match /listFollowers/{followerId} {
      allow read: if isRegisteredUser();
      allow create: if isRegisteredUser() && request.resource.data.userId == request.auth.uid;
      allow delete: if isRegisteredUser() && resource.data.userId == request.auth.uid;
    }

    match /projectMembers/{memberId} {
      allow read: if isRegisteredUser() && canAccessProject(resource.data.projectId);
      allow create, update, delete: if false;
    }

    match /shares/{shareId} {
      allow read: if isRegisteredUser()
        && (resource.data.toUserId == request.auth.uid || resource.data.createdBy == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /invites/{inviteId} {
      allow read, create, update, delete: if false;
    }

    match /handleReservations/{handle} {
      allow read, create, update, delete: if false;
    }

    match /subscriptionEntitlements/{userId} {
      allow read: if isRegisteredUser() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /subscriptionUsage/{userId} {
      allow read: if isRegisteredUser() && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    match /revenueCatWebhookEvents/{eventId} {
      allow read, create, update, delete: if false;
    }
  }
}
